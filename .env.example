# Copie este arquivo para .env e preencha os valores reais
# cp .env.example .env

# Mercado Pago — necessário para pagamentos funcionarem
# Pegue em: https://www.mercadopago.com.br/developers → Credenciais
MERCADOPAGO_ACCESS_TOKEN=TEST-seu-access-token-aqui

# Webhook secret — configure igual ao painel MP Developer → Webhooks
MERCADOPAGO_WEBHOOK_SECRET=dev-only-insecure-webhook-secret

# URL pública do backend (use sua URL do ngrok para receber webhooks localmente)
# APP_BASE_URL=https://abc123.ngrok.io

# Mude em produção
JWT_SECRET=dev-only-insecure-secret-key-change-in-prod
